{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp"
    },
    "notion": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.notion.com/mcp",
      "oauth": {}
    },
    "control-chrome": {
      "type": "local",
      "enabled": true,
      "command": [
        "chrome-devtools-mcp"
      ]
    },
    "sentry": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    }
  },
  "plugin": [
    "opencode-scheduler"
  ],
  "model": "opencode/kimi-k2.5-free"
}
